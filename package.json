{
    "name": "flowfuse-website",
    "version": "1.0.0",
    "private": true,
    "description": "",
    "keywords": [],
    "license": "Apache-2.0",
    "author": "Nick O'Leary",
    "workspaces": ["nuxt"],
    "scripts": {
        "dev": "concurrently \"npm run dev:postcss-nuxt\" \"npm run dev:docs\" \"npm run dev:blueprints\" \"npm run dev --workspace=nuxt\"",
        "start": "npm run dev",
        "dev:docs": "node scripts/copy_docs.js --watch",
        "dev:blueprints": "node scripts/watch_blueprints.js",
        "dev:postcss-nuxt": "dotenv -v TAILWIND_MODE=watch -- npx postcss ./src/css/style.css -o ./nuxt/public/css/style.css --config ./postcss.config.js -w",
        "docs": "node scripts/copy_docs.js",
        "docs-nuxt": "node scripts/copy_docs_nuxt.js",
        "handbook": "node scripts/copy_handbook.js",
        "changelog": "node scripts/copy_changelog.js",
        "blog": "node scripts/copy_blog.js",
        "customer-stories": "node scripts/copy_customer_stories.js",
        "events": "node scripts/copy_events.js",
        "integrations": "node scripts/copy_integrations.js",
        "node-red": "node scripts/copy_node_red.js",
        "ebooks": "node scripts/copy_ebooks.js",
        "icons": "node scripts/copy_icons.js",
        "team": "node scripts/copy_team.js",
        "blueprints": "node scripts/copy_blueprints.js",
        "assets": "node scripts/copy_assets.js",
        "legacy-static": "node scripts/copy_legacy_static.js",
        "sitemap": "node scripts/gen_sitemap.js",
        "index:algolia": "node scripts/index-algolia.js",
        "build:js:nuxt": "terser -c -m -o nuxt/public/js/cc.min.js node_modules/vanilla-cookieconsent/dist/cookieconsent.umd.js src/js/cookieconsent-config.js && cp node_modules/@flowfuse/flow-renderer/index.min.js nuxt/public/js/flowrenderer.min.js",
        "prod:postcss-nuxt": "postcss ./src/css/style.css -o ./nuxt/public/css/style.css --config ./postcss.config.js",
        "prod:nuxt": "npm run generate --workspace=nuxt",
        "clean:nuxt": "npx del-cli 'nuxt/public/**/*.html' 'nuxt/public/search-index.json' 'nuxt/.output' && npx mkdirp 'nuxt/public/js' 'nuxt/public/css'",
        "build:nuxt": "dotenv -v NODE_ENV=production -- npm-run-all2 clean:nuxt build:js:nuxt docs docs-nuxt handbook changelog blog customer-stories events integrations node-red ebooks icons team blueprints assets legacy-static prod:postcss-nuxt prod:nuxt sitemap",
        "build:nuxt:skip-images": "dotenv -v SKIP_IMAGES=true -v NODE_ENV=production -- npm-run-all2 clean:nuxt build:js:nuxt docs docs-nuxt handbook changelog blog customer-stories events integrations node-red ebooks icons team blueprints assets legacy-static prod:postcss-nuxt prod:nuxt sitemap",
        "build": "npm run build:nuxt",
        "build:indexed": "npm run build:nuxt && npm run index:algolia"
    },
    "devDependencies": {
        "concurrently": "^9.0.0",
        "@11ty/eleventy-img": "^3.1.8",
        "@flowforge/forge-ui-components": "^0.2.2",
        "@tailwindcss/typography": "^0.5.10",
        "autoprefixer": "^10.4.17",
        "del-cli": "^5.0.0",
        "dotenv-cli": "^7.4.4",
        "html-minifier-terser": "^7.2.0",
        "markdown-it-anchor": "^8.6.7",
        "markdown-it-footnote": "^3.0.3",
        "netlify-plugin-cache": "^1.0.3",
        "nodemon": "^2.0.20",
        "npm-run-all2": "^7.0.1",
        "postcss": "^8.5.10",
        "postcss-cli": "^9.0.1",
        "postcss-import": "^14.0.2",
        "postcss-minify": "^1.1.0",
        "seedrandom": "^3.0.5",
        "spacetime": "^7.4.7",
        "tailwindcss": "^3.4.19",
        "terser": "^5.9.0",
        "vanilla-cookieconsent": "^3.0.0"
    },
    "overrides": {
        "yaml": ">=1.10.3",
        "simple-update-notifier": {
            "semver": ">=7.5.2"
        }
    },
    "dependencies": {
        "@11ty/eleventy-fetch": "^4.0.0",
        "@flowfuse/flow-renderer": "^0.5.0",
        "@netlify/blobs": "^10.3.0",
        "@xmldom/xmldom": "^0.8.13",
        "algoliasearch": "^4.25.3",
        "codeowners": "^5.1.1",
        "js-yaml": "^4.1.1",
        "markdown-it-attrs": "^4.1.6",
        "xpath": "^0.0.34"
    }
}
