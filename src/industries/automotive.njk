<!-- ============================================================
     HERO
============================================================ -->
<section class="w-full relative">
    <div class="px-6 pt-16 pb-14 md:pt-20">
        <div class="max-w-screen-lg mx-auto grid md:grid-cols-2 gap-12 items-stretch">
            <div class="max-md:text-center">
                <h1 class="text-4xl md:text-5xl font-medium m-0">
                    {{ hero.heading | safe }}
                </h1>
                <p class="mt-6 text-gray-700">{{ hero.description }}</p>
                <div class="mt-8 flex gap-4 items-center max-md:justify-center flex-wrap">
                    <a class="ff-btn ff-btn--highlight uppercase"
                        href="{{ hero.primaryCtaLink }}"
                        onclick="capture('cta-book-demo', {'position': 'hero'})">
                        {{ hero.primaryCta }}
                    </a>
                    <a class="flex items-center gap-2 text-base uppercase font-bold text-indigo-600 hover:text-indigo-800"
                        href="{{ hero.secondaryCtaLink }}"
                        onclick="capture('cta-pricing', {'position': 'hero'})">
                        {{ hero.secondaryCta }}
                        {% include "components/icons/arrow-right.svg" %}
                    </a>
                </div>
            </div>
            <div class="w-full md:flex md:items-center">
                {% if hero.testimonial and hero.testimonial.quote %}
                <div class="relative w-full md:pt-6 max-md:mt-10">
                    <div class="relative rounded-lg border border-indigo-200 p-6 pt-28 bg-indigo-50/50">
                        <div class="absolute -top-14 left-1/2 -translate-x-1/2 md:left-8 md:translate-x-0 w-36 h-36 rounded-full bg-red-200 border-4 border-white shadow-lg overflow-hidden ff-image-cover">
                            {% image hero.testimonial.avatar, hero.testimonial.name %}
                        </div>
                        <p class="italic text-gray-600 font-medium m-0">&ldquo;{{ hero.testimonial.quote }}&rdquo;</p>
                        <p class="text-gray-500 text-right mt-4 mb-0">{{ hero.testimonial.name }}, {{ hero.testimonial.title }} <span class="font-semibold text-gray-600">{{ hero.testimonial.company }}</span></p>
                    </div>
                </div>
                {% else %}
                <div class="relative w-full h-full">
                    <div class="ff-image-cover ff-image-rounded w-full h-full">
                        {% image ["./", hero.image] | join, hero.imageAlt, [496] %}
                    </div>
                </div>
                {% endif %}
            </div>
        </div>
        <div class="max-w-screen-lg mx-auto mt-16 text-center">
            <p class="text-gray-500 text-lg font-semibold">{{ hero.trustedByText }}</p>
            <div class="mx-auto text-center -mt-0.5 bg-radial-indigo -mb-10">
                {% include "social-proof.njk" %}
            </div>
        </div>
    </div>
</section>

<!-- ============================================================
     NOT EVERY PRODUCTION CHALLENGE
============================================================ -->
<section class="w-full py-16 md:py-24 px-6 bg-white">
    <div class="max-w-screen-lg mx-auto flex flex-col md:flex-row gap-12 items-stretch">
        <div class="md:w-1/2 relative">
            <div class="ff-image-cover ff-image-rounded w-full h-full">
                {% image ["./", problem.image] | join, problem.imageAlt, [720] %}
            </div>
        </div>
        <div class="md:w-1/2 max-md:text-center md:pt-6 self-center">
            <h2 class="text-gray-700">{{ problem.heading }}</h2>
            <p class="text-gray-700">{{ problem.description }}</p>
        </div>
    </div>
</section>

<!-- ============================================================
     APPLICATIONS FOR AUTOMOTIVE MANUFACTURING
============================================================ -->
<section class="w-full relative py-20 px-6 overflow-hidden">
    <div class="absolute inset-x-0 top-0 h-[400px] md:h-[561px] solution-section-bg-flipped" aria-hidden="true"></div>
    <div class="relative z-10">
    {% set variants = {
        "indigo": { gradient: "from-indigo-400 via-indigo-300 to-indigo-100", border: "border-indigo-300", mobileGradient: "from-indigo-100 to-indigo-50", mobileBorder: "border-indigo-200" },
        "red": { gradient: "from-red-200 via-red-100 to-red-50", border: "border-red-100", mobileGradient: "from-red-50 to-white", mobileBorder: "border-red-100" },
        "mixed": { gradient: "from-red-200 to-indigo-100", border: "border-indigo-100", mobileGradient: "from-red-50 to-indigo-50", mobileBorder: "border-indigo-100" }
    } %}
    <div class="max-w-screen-lg mx-auto max-md:text-center mb-28 md:mt-10">
        <h2 class="text-indigo-600 text-4xl md:text-5xl">{{ applications.heading }}</h2>
        <p class="text-gray-600 text-lgmd:text-2xl">{{ applications.description }}</p>
    </div>

    <div class="md:max-w-screen-lg mx-auto">
        {% for item in applications.items %}
        {% set v = variants[item.variant] %}
        {% set imageOnLeft = loop.index is odd %}
        <div class="max-md:text-center md:flex md:flex-row gap-8 items-center m-auto{% if not imageOnLeft %} md:flex-row-reverse{% endif %} mb-14 md:mb-20">
            <!-- Image (desktop): full-size screenshot offset over a colored panel -->
            <div class="max-md:hidden md:w-[45%]">
                <div class="relative aspect-[430/289]">
                    <div class="absolute -top-5 w-full h-full{% if imageOnLeft %} -left-5{% else %} -right-5{% endif %} rounded-lg bg-gradient-to-tl {{ v.gradient }}"></div>
                    <div class="absolute inset-0 rounded-lg border-2 {{ v.border }} overflow-hidden ff-image-cover">
                        {% image ["./", item.image] | join, item.imageAlt, [860] %}
                    </div>
                </div>
            </div>
            <!-- Text -->
            <div class="md:w-[55%] flex flex-col gap-3">
                <h3 class="text-gray-700 text-3xl font-medium m-0">{{ item.title }}</h3>
                <div class="md:hidden rounded-xl w-full bg-gradient-to-tl {{ v.mobileGradient }} max-w-[500px] mx-auto my-4 p-4">
                    <div class="ff-image-rounded w-full border {{ v.mobileBorder }} overflow-hidden">
                        {% image ["./", item.image] | join, item.imageAlt, [440] %}
                    </div>
                </div>
                <p class="text-gray-500 m-0">{{ item.description }}</p>
                <a href="{{ item.linkHref }}" class="flex items-center gap-1.5 text-blue-600 hover:underline max-md:justify-center">
                    {{ item.linkText }}
                    {% include "components/icons/arrow-long-right.svg" %}
                </a>
            </div>
        </div>
        {% endfor %}
    </div>
    </div>
</section>

<!-- ============================================================
     BUILT FOR ENTERPRISE MANUFACTURING
============================================================ -->
<section class="w-full comparison-section-bg py-20 px-6">
    <div class="max-w-screen-lg mx-auto flex flex-col md:flex-row gap-12 items-center justify-between">
        <div class="shrink md:shrink md:basis-2/5 md:min-w-0 max-md:text-center">
            <h2 class="m-0">{{ enterprise.heading | safe }}</h2>
            <p class="text-gray-600">{{ enterprise.description }}</p>
            <a href="{{ enterprise.linkHref }}" class="flex items-center gap-1.5 text-blue-600 hover:underline max-md:justify-center">
                {{ enterprise.linkText }}
                {% include "components/icons/arrow-long-right.svg" %}
            </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-7 gap-4 w-full max-w-md md:max-w-[646px] md:shrink md:basis-3/5 md:min-w-0">
            <div class="col-span-2 md:col-span-3 md:row-span-2 flex flex-col items-center justify-between gap-4 rounded-xl border border-white p-5 bg-[linear-gradient(135deg,_theme(colors.white)_0%,_theme(colors.white/10%)_100%)]">
                <div class="w-full max-w-[220px] aspect-square m-auto">
                    {% include enterprise.badge %}
                </div>
                <p class="text-gray-500 text-sm m-0">{{ enterprise.badgeLabel }}</p>
            </div>
            {% for item in enterprise.items %}
            <div class="md:col-span-2 flex flex-col gap-2 items-center justify-center text-center rounded-xl border border-white p-3 bg-[linear-gradient(135deg,_theme(colors.white)_0%,_theme(colors.white/10%)_100%)]">
                <div class="w-full max-w-14 aspect-square">
                    {% include item.icon %}
                </div>
                <p class="text-gray-600 text-sm m-0">{{ item.label }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- ============================================================
     FAQ
============================================================ -->
<div class="w-full px-6 pt-20 pb-10">
    <div class="max-w-screen-lg mx-auto">
        <h2 class="mb-1 text-center md:text-left">Frequently Asked <span class="text-indigo-600">Questions</span></h2>
        <div class="-mt-20">
        {% include "faq.njk" %}
        </div>
    </div>
</div>

<!-- ============================================================
     CTA
============================================================ -->
<div class="w-full px-6 pb-20">
    <div class="max-w-screen-lg mx-auto">
        {% include "cta-get-started.njk" %}
    </div>
</div>
