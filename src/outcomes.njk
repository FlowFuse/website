---
layout: layouts/base.njk
sitemapPriority: 0.8
title: "Outcomes"
meta:
  title: "Outcomes"
  description: "The outcomes FlowFuse customers buy: production performance, quality and compliance, efficiency, reliability, and AI readiness. Each backed by concrete use cases."
---
<div class="w-full">

    <!-- HERO -->
    <div class="w-full px-6 bg-[radial-gradient(ellipse_120%_140%_at_50%_-20%,theme(colors.indigo.50)_0%,theme(colors.white)_60%)]">
        <div class="max-w-screen-lg mx-auto py-16 sm:py-24 text-center">
            <p class="uppercase text-sm font-semibold text-indigo-500 mb-4">Outcomes</p>
            <h1 class="m-auto max-w-3xl font-medium">What FlowFuse <span class="text-indigo-600">moves</span></h1>
            <p class="mt-6 max-w-2xl mx-auto text-lg text-gray-600">Five outcomes operations leaders are accountable for, each delivered through concrete use cases your team owns end to end.</p>
        </div>
    </div>

    <!-- OUTCOME CARD GRID (derived from the value-pillar collection) -->
    <div class="w-full py-16 sm:py-24 px-6 bg-white">
        <div class="max-w-screen-lg mx-auto">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                {% for pillar in collections["value-pillar"] | sort(false, true, "data.title") %}
                <a href="{{ pillar.url }}" class="group hover:no-underline flex flex-col gap-3 rounded-xl border border-gray-200 p-6 bg-white hover:border-indigo-300 hover:shadow-sm transition-all">
                    <h3 class="m-0 text-gray-800 group-hover:text-indigo-600 transition-colors">{{ pillar.data.title }}</h3>
                    <p class="m-0 text-gray-600 text-sm flex-grow">{{ pillar.data.problem }}</p>
                    <span class="ff-animated-link mt-2 text-indigo-600 text-sm font-semibold flex items-center gap-2">
                        View outcome
                        <span class="w-4 h-4">{% include "components/icons/arrow-right.svg" %}</span>
                    </span>
                </a>
                {% endfor %}
            </div>
        </div>
    </div>

    <!-- CLOSING CTA BAND -->
    <div class="w-full px-6 py-20">
        <div class="ff-blue-card max-md:max-w-xl md:max-w-screen-lg mx-auto pt-12 pb-10 text-center">
            <h3 class="mb-4 w-full text-center">Which outcome are you accountable for?</h3>
            <p class="text-gray-600 mb-8 max-w-xl mx-auto text-center">Talk to an expert about the use cases behind it, or get started with FlowFuse today.</p>
            <div class="flex flex-wrap gap-4 justify-center">
                <a class="ff-btn ff-btn--highlight min-h-[40px] uppercase" href="/contact-us/" onclick="capture('cta-talk-to-expert', {'position': 'footer', 'page': 'outcomes-hub'})">Talk to an expert</a>
                <a class="ff-btn ff-btn--primary-outlined min-h-[40px] uppercase" href="{% include "sign-up-url.njk" %}" onclick="capture('cta-join', {'position': 'footer', 'page': 'outcomes-hub'})">Get started</a>
            </div>
        </div>
    </div>

</div>
