{% set authorSlug = authors[0] if authors and authors.length else null %}
{% set author = people[authorSlug] if authorSlug else null %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://flowfuse.com/#organization",
      "name": "FlowFuse",
      "legalName": "FlowFuse Inc.",
      "alternateName": ["Flow Fuse"],
      "url": "https://flowfuse.com",
      "description": "FlowFuse is the universal platform that powers your factory, creating a secure and governed solution for your industrial operations.",
      "foundingDate": "2021",
      "logo": {
        "@type": "ImageObject",
        "url": "https://flowfuse.com/handbook/images/logos/ff-logo--square--dark.png"
      },
      "sameAs": [
        "https://www.linkedin.com/company/flowfuse",
        "https://github.com/FlowFuse",
        "https://www.youtube.com/@FlowFuseInc",
        "https://twitter.com/FlowFuseInc",
        "https://www.crunchbase.com/organization/flowforge",
        "https://www.g2.com/sellers/flowfuse",
        "https://www.facebook.com/FlowFuse",
        "https://www.reddit.com/r/FlowFuse/"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://flowfuse.com/#website",
      "url": "https://flowfuse.com",
      "name": "FlowFuse",
      "description": "{{ site.messaging.title }}",
      "publisher": {
        "@id": "https://flowfuse.com/#organization"
      }
    },
    {
      "@type": "WebPage",
      "@id": "https://flowfuse.com{{ page.url }}#webpage",
      "url": "https://flowfuse.com{{ page.url }}",
      "name": "{{ title or site.messaging.title }}",
      "headline": "{{ title or site.messaging.title }}",
      "description": "{{ description or site.messaging.subtitle }}",
      "isPartOf": {
        "@id": "https://flowfuse.com/#website"
      },
      {% if image %}
      "primaryImageOfPage": {
        "@type": "ImageObject",
        "url": "{% if image.startsWith('http') %}{{ image }}{% else %}https://flowfuse.com{{ image }}{% endif %}"
      },
      {% endif %}
      "publisher": {
        "@id": "https://flowfuse.com/#organization"
      }
    },
    {
      "@type": "SoftwareApplication",
      "@id": "https://flowfuse.com/#software",
      "name": "FlowFuse",
      "url": "https://flowfuse.com",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Cross-platform, Linux, Docker, Kubernetes",
      "publisher": {
        "@id": "https://flowfuse.com/#organization"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "ratingCount": "4",
        "bestRating": "5",
        "worstRating": "1",
        "reviewCount": "4",
        "url": "https://www.g2.com/sellers/flowfuse"
      }
    }
    {% if type == "post" %}
    ,
    {
      "@type": "BlogPosting",
      "@id": "https://flowfuse.com{{ page.url }}#blogposting",
      "mainEntityOfPage": {
        "@id": "https://flowfuse.com{{ page.url }}#webpage"
      },
      "headline": "{{ title }}",
      "description": "{{ description }}",
      {% if image %}
      "image": "{% if image.startsWith('http') %}{{ image }}{% else %}https://flowfuse.com{{ image }}{% endif %}",
      {% endif %}
      "datePublished": "{{ date | dateToRfc3339 }}",
      "dateModified": "{{ (lastUpdated or date) | dateToRfc3339 }}",
      {% if author %}
      "author": {
        "@type": "Person",
        "@id": "https://flowfuse.com/about/#{{ authorSlug }}",
        "name": "{{ author.name }}",
        {% if author.title %}"jobTitle": "{{ author.title }}",{% endif %}
        "url": "https://flowfuse.com/about/#{{ authorSlug }}",
        {% if author.headshot %}"image": "https://flowfuse.com/images/team/headshot-{{ author.headshot | replace('.png','') | replace('.jpg','') | replace('.jpeg','') }}.png",{% endif %}
        {% if author.bio %}"description": {{ author.bio | dump | safe }},{% endif %}
        {% if author.knowsAbout %}"knowsAbout": {{ author.knowsAbout | dump | safe }},{% endif %}
        "worksFor": { "@id": "https://flowfuse.com/#organization" },
        "sameAs": [
          {% set socials = [] %}
          {% if author.linkedin %}{% set socials = (socials.push("https://www.linkedin.com/in/" + author.linkedin), socials) %}{% endif %}
          {% if author.github %}{% set socials = (socials.push("https://github.com/" + author.github), socials) %}{% endif %}
          {% if author.twitter %}{% set socials = (socials.push("https://twitter.com/" + author.twitter), socials) %}{% endif %}
          {% for url in socials %}"{{ url }}"{% if not loop.last %},{% endif %}{% endfor %}
        ]
      },
      {% else %}
      "author": { "@id": "https://flowfuse.com/#organization" },
      {% endif %}
      "publisher": {
        "@id": "https://flowfuse.com/#organization"
      }
    }
    {% endif %}
     {% if meta.faq %}
    ,
    {
      "@type": "FAQPage",
      "@id": "https://flowfuse.com{{ page.url }}#faq",
      "mainEntity": [
        {% for item in meta.faq %}
        {
          "@type": "Question",
          "name": "{{ item.question }}",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "{{ item.answer }}"
          }
        }{% if not loop.last %},{% endif %}
        {% endfor %}
      ]
    }
    {% endif %}
    {% if meta.howto %}
    ,
    {
      "@type": "HowTo",
      "@id": "https://flowfuse.com{{ page.url }}#howto",
      "name": "{{ meta.howto.name or title }}",
      "description": "{{ meta.howto.description or description }}",
      {% if meta.howto.totalTime %}"totalTime": "{{ meta.howto.totalTime }}",{% endif %}
      {% if meta.howto.tool %}
      "tool": [
        {% for t in meta.howto.tool %}
        { "@type": "HowToTool", "name": "{{ t }}" }{% if not loop.last %},{% endif %}
        {% endfor %}
      ],
      {% endif %}
      "step": [
        {% for s in meta.howto.steps %}
        {
          "@type": "HowToStep",
          "position": {{ loop.index }},
          "name": "{{ s.name }}",
          "text": "{{ s.text }}"
          {% if s.url %},"url": "https://flowfuse.com{{ page.url }}#{{ s.url }}"{% endif %}
        }{% if not loop.last %},{% endif %}
        {% endfor %}
      ]
    }
    {% endif %}
  ]
}
</script>
