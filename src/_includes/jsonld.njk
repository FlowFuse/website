{% set authorSlug = authors[0] if authors and authors.length else null %}
{% set author = people[authorSlug] if authorSlug else null %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "{{ site.baseURL }}/#organization",
      "name": "FlowFuse",
      "legalName": "{{ site.organization.legalName }}",
      "alternateName": {{ site.organization.alternateName | dump | safe }},
      "url": "{{ site.baseURL }}",
      "description": "{{ site.messaging.subtitle }}",
      "foundingDate": "{{ site.organization.foundingDate }}",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ site.organization.logo }}"
      },
      "sameAs": {{ site.organization.sameAs | dump | safe }}
    },
    {
      "@type": "WebSite",
      "@id": "{{ site.baseURL }}/#website",
      "url": "{{ site.baseURL }}",
      "name": "FlowFuse",
      "description": "{{ site.messaging.title }}",
      "publisher": {
        "@id": "{{ site.baseURL }}/#organization"
      }
    },
    {
      "@type": "WebPage",
      "@id": "{{ site.baseURL }}{{ page.url }}#webpage",
      "url": "{{ site.baseURL }}{{ page.url }}",
      "name": "{{ title or site.messaging.title }}",
      "headline": "{{ title or site.messaging.title }}",
      "description": "{{ description or site.messaging.subtitle }}",
      "isPartOf": {
        "@id": "{{ site.baseURL }}/#website"
      },
      {% if image %}
      "primaryImageOfPage": {
        "@type": "ImageObject",
        "url": "{% if image.startsWith('http') %}{{ image }}{% else %}{{ site.baseURL }}{{ image }}{% endif %}"
      },
      {% endif %}
      "publisher": {
        "@id": "{{ site.baseURL }}/#organization"
      }
    },
    {
      "@type": "SoftwareApplication",
      "@id": "{{ site.baseURL }}/#software",
      "name": "FlowFuse",
      "url": "{{ site.baseURL }}",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Cross-platform, Linux, Docker, Kubernetes",
      "publisher": {
        "@id": "{{ site.baseURL }}/#organization"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "ratingCount": "4",
        "bestRating": "5",
        "worstRating": "1",
        "reviewCount": "4",
        "url": "https://www.g2.com/sellers/flowfuse"
      }
    }
    {% if type == "post" %}
    ,
    {
      "@type": "BlogPosting",
      "@id": "{{ site.baseURL }}{{ page.url }}#blogposting",
      "mainEntityOfPage": {
        "@id": "{{ site.baseURL }}{{ page.url }}#webpage"
      },
      "headline": "{{ title }}",
      "description": "{{ description }}",
      {% if image %}
      "image": "{% if image.startsWith('http') %}{{ image }}{% else %}{{ site.baseURL }}{{ image }}{% endif %}",
      {% endif %}
      "datePublished": "{{ date | dateToRfc3339 }}",
      "dateModified": "{{ (lastUpdated or date) | dateToRfc3339 }}",
      {% if author %}
      "author": {
        "@type": "Person",
        "@id": "{{ site.baseURL }}/about/#{{ authorSlug }}",
        "name": "{{ author.name }}",
        {% if author.title %}"jobTitle": "{{ author.title }}",{% endif %}
        "url": "{{ site.baseURL }}/about/#{{ authorSlug }}",
        {% if author.headshot %}"image": "{{ site.baseURL }}/images/team/headshot-{{ author.headshot | replace('.png','') | replace('.jpg','') | replace('.jpeg','') }}.png",{% endif %}
        {% if author.bio %}"description": {{ author.bio | dump | safe }},{% endif %}
        {% if author.knowsAbout %}"knowsAbout": {{ author.knowsAbout | dump | safe }},{% endif %}
        "worksFor": { "@id": "{{ site.baseURL }}/#organization" },
        {% set socials = [] %}
        {% if author.linkedin %}{% set socials = (socials.push("https://www.linkedin.com/in/" + author.linkedin), socials) %}{% endif %}
        {% if author.github %}{% set socials = (socials.push("https://github.com/" + author.github), socials) %}{% endif %}
        {% if author.twitter %}{% set socials = (socials.push("https://twitter.com/" + author.twitter), socials) %}{% endif %}
        "sameAs": {{ socials | dump | safe }}
      },
      {% else %}
      "author": { "@id": "{{ site.baseURL }}/#organization" },
      {% endif %}
      "publisher": {
        "@id": "{{ site.baseURL }}/#organization"
      }
    }
    {% endif %}
     {% if meta.faq %}
    ,
    {
      "@type": "FAQPage",
      "@id": "{{ site.baseURL }}{{ page.url }}#faq",
      "mainEntity": [
        {% for item in meta.faq %}
        {
          "@type": "Question",
          "name": "{{ item.question }}",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "{{ item.answer }}"
          }
        }{% if not loop.last %},{% endif %}
        {% endfor %}
      ]
    }
    {% endif %}
    {% if meta.howto %}
    ,
    {
      "@type": "HowTo",
      "@id": "{{ site.baseURL }}{{ page.url }}#howto",
      "name": "{{ meta.howto.name or title }}",
      "description": "{{ meta.howto.description or description }}",
      {% if meta.howto.totalTime %}"totalTime": "{{ meta.howto.totalTime }}",{% endif %}
      {% if meta.howto.tool %}
      "tool": [
        {% for t in meta.howto.tool %}
        { "@type": "HowToTool", "name": "{{ t }}" }{% if not loop.last %},{% endif %}
        {% endfor %}
      ],
      {% endif %}
      "step": [
        {% for s in meta.howto.steps %}
        {
          "@type": "HowToStep",
          "position": {{ loop.index }},
          "name": "{{ s.name }}",
          "text": "{{ s.text }}"
          {% if s.url %},"url": "{{ site.baseURL }}{{ page.url }}#{{ s.url }}"{% endif %}
        }{% if not loop.last %},{% endif %}
        {% endfor %}
      ]
    }
    {% endif %}
  ]
}
</script>
