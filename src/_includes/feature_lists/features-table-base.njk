{# Column header — outside overflow container so sticky works on mobile #}
<div class="sticky top-[140px] sm:top-[164px] md:top-[116px] z-10 transition-colors duration-200" data-sticky-header>
    <div class="overflow-hidden sm:overflow-visible" data-table-header>
        <div class="ff-feature-table m-auto">
            <ul class="{{ hosting }} ff-feature-table-section">
                <li class="ff-feature--column-header">
                    <span class="sticky left-0 h-full bg-white"></span>
                    {% if hosting == "self-hosted" %}
                    <label>Open Source</label>
                    {% endif %}
                    <label>Pro</label>
                    <label>Enterprise</label>
                </li>
            </ul>
        </div>
    </div>
</div>

{# Table body — horizontally scrollable on mobile #}
<div class="overflow-x-auto sm:overflow-x-visible" data-table-body>
    <div class="ff-feature-table ff-feature-table--body m-auto">
        {% set hostingKey = 'selfHosted' if hosting == 'self-hosted' else 'cloud' %}
        {% set tiers = ['openSource', 'pro', 'enterprise'] if hosting == 'self-hosted' else ['pro', 'enterprise'] %}

        {% asyncAll section in featureCatalog.sections %}
        <ul class="{{ hosting }} ff-feature-table-section">
            <li class="ff-feature--header sm:sticky sm:top-[208px] md:top-[160px]">
                <span class="sticky left-0 h-full">{{ section.label }}</span>
                {% for tier in tiers %}
                <span></span>
                {% endfor %}
            </li>
            {% asyncAll row in section.features %}
            {% if row.showOnPricing and hosting in row.tags %}
            {% set hostingData = row[hostingKey] %}
            <li class="ff-feature-row" id="ff-feature--{{ row.id }}-{{ hosting }}">
                <label {% if row.description %}class="sticky left-0 h-full{% if row.subfeature %} pl-5 text-gray-500{% endif %}" role="button" tabindex="0" onclick="openInfo('{{ row.id }}', '{{ hosting }}')" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();openInfo('{{ row.id }}','{{ hosting }}');}"{% else %}class="sticky left-0 h-full pointer-events-none{% if row.subfeature %} pl-5 text-gray-500{% endif %}"{% endif %}>
                    {% if row.subfeature %}└ {% endif %}{{ row.label }}{% if row.beta %} <span class="ff-feature-note ml-1">Beta</span>{% endif %}
                    {% if row.description %}
                    <i id="ff-info--{{ row.id }}-{{ hosting }}" class="ff-icon min-w-[20px]">{% include "components/icons/info.svg" %}</i>
                    {% endif %}
                </label>
                {% asyncAll tier in tiers %}
                {% set cell = hostingData[tier] if hostingData else null %}
                <span>
                    {% if cell and cell.value === true %}
                        {% if cell.dimmed %}<span class="opacity-40">{% endif %}{% include "components/feature-check.svg" %}{% if cell.dimmed %}</span>{% endif %}
                    {% elif cell and cell.value === 'time' %}
                        {% tooltip "On the roadmap" %}
                        {% include "components/feature-time.svg" %}
                        {% endtooltip %}
                    {% elif cell and cell.value === 'optional' %}
                        {% include "components/feature-optional.svg" %}
                    {% elif cell and cell.value === 'addon' %}
                        {% include "components/feature-addon.svg" %}
                    {% elif cell and cell.value === 'contact' %}
                        <a href="/contact-us" class="ff-btn ff-btn--primary-outlined uppercase grow mx-1">Contact Us</a>
                    {% elif cell and cell.value === 'list' %}
                        {% for opt in cell.options %}{{ opt }}{% if not loop.last %}<br>{% endif %}{% endfor %}
                    {% elif cell and cell.value %}
                        {{ cell.value }}
                    {% elif cell and cell.tag %}
                        {% if cell.tagPrefix %}{{ cell.tagPrefix }} {% endif %}<span class="ff-feature-note{% if cell.tagPrefix %} ml-1{% endif %}">{{ cell.tag }}</span>
                    {% else %}
                        <span class="text-gray-300">&mdash;</span>
                    {% endif %}
                </span>
                {% endall %}
            </li>
            {% endif %}
            {% endall %}
        </ul>
        {% endall %}
        <ul class="{{ hosting }} ff-feature-table-section">
            <li class="ff-feature--column-buttons mt-6 h-10 gap-x-3">
            {% if hosting == "cloud" %}
                {% set buttons = featureCatalog.buttons.cloud %}
            {% elif hosting == "self-hosted" %}
                {% set buttons = featureCatalog.buttons.selfHosted %}
            {% endif %}
            <label class="align-baseline w-full text-center"></label>
            {% for button in buttons %}
                {% set buttonUrl = button.url %}
                {% if button.url == 'sign-up-url' %}
                    {% set buttonUrl %}{% include "sign-up-url.njk" %}{% endset %}
                {% endif %}
                <label><a class="ff-btn {{ 'ff-btn--primary' if loop.last else 'ff-btn--primary-outlined' }} uppercase align-baseline w-full text-center" href="{{ buttonUrl }}" {% if button.onclick %} onclick="{{ button.onclick }}" {% endif %}>{{ button.cta }}</a></label>
            {% endfor %}
            </li>
        </ul>
    </div>
</div>

<div id="feature-dialogs">
    {% set hostingKey = 'selfHosted' if hosting == 'self-hosted' else 'cloud' %}
    {% set tiers = ['openSource', 'pro', 'enterprise'] if hosting == 'self-hosted' else ['pro', 'enterprise'] %}
    {% set tierLabels = {"openSource": "Open Source", "pro": "Pro", "enterprise": "Enterprise"} %}
    {% asyncAll section in featureCatalog.sections %}
    {% asyncAll row in section.features %}
    {% if row.showOnPricing and row.description %}
    <div id="ff-dialog--feature--{{ row.id }}-{{ hosting }}" class="ff-dialog-container" role="dialog" aria-modal="true" aria-labelledby="ff-dialog--header-{{ row.id }}-{{ hosting }}">
        <div class="ff-dialog-shadow" role="button" tabindex="0" aria-label="Close dialog" onclick="closeInfo('{{ row.id }}', '{{ hosting }}')" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();closeInfo('{{ row.id }}','{{ hosting }}');}"></div>
        <div class="ff-dialog-modal">
            <div id="ff-dialog--header-{{ row.id }}-{{ hosting }}" class="ff-dialog-header">Feature: {{ row.label }}</div>
            <div id="ff-dialog--content" class="ff-dialog-content">
                <p>{{ row.description }}</p>
                {% set hostingData = row[hostingKey] %}
                {% asyncAll tier in tiers %}
                {% set cell = hostingData[tier] if hostingData else null %}
                {% if cell and cell.note %}
                <p><strong>{{ tierLabels[tier] }}:</strong> {{ cell.note }}</p>
                {% endif %}
                {% endall %}
                {% if row.docsLink %}
                <p><a href="{{ row.docsLink }}" target="_blank" rel="noopener">Learn more</a></p>
                {% endif %}
            </div>
        </div>
    </div>
    {% endif %}
    {% endall %}
    {% endall %}
</div>
