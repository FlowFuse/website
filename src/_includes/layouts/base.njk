<script>
    document.getElementById('nav-toggle').onclick = function(){
        var toggle = document.getElementById("nav-toggle");
        var header = document.getElementById("ff-header");
        var nav = document.getElementById("nav-content");
        var willOpen = !header.classList.contains("mobile-open");
        toggle.classList.toggle("mobile-open");
        header.classList.toggle("mobile-open");
        // Lock background scroll while the mobile drawer is open. Lock the
        // scroll container (html) only: locking html AND body together makes
        // the sticky header revert to its static position.
        document.documentElement.classList.toggle("nav-scroll-lock", willOpen);
        if (willOpen) {
            // Anchor the drawer to the header's live bottom edge: just below the
            // (scroll-away) utility bar at the top of the page, or just below the
            // sticky header once scrolled. Scroll is locked, so this stays valid.
            nav.style.top = header.getBoundingClientRect().bottom + "px";
        } else {
            nav.style.top = "";
        }
    };
    // Growing past the mobile breakpoint must clear any open-drawer state + scroll lock
    window.addEventListener('resize', function(){
        if (window.innerWidth >= 768) {
            document.getElementById("nav-toggle").classList.remove("mobile-open");
            document.getElementById("ff-header").classList.remove("mobile-open");
            document.documentElement.classList.remove("nav-scroll-lock");
            document.getElementById("nav-content").style.top = "";
        }
    });

    // Nav overflow: move non-dropdown items into "More" when they don't fit
    (function() {
        var nav = document.getElementById('nav-content');
        var headerNav = document.querySelector('.ff-header nav');
        var moreItem = document.getElementById('nav-more');
        var moreList = document.getElementById('nav-more-list');
        if (!nav || !moreItem || !moreList || !headerNav) return;

        function isOverflowing() {
            var overflowBuffer = 24;
            // Check if the last child of <nav> extends past the viewport
            var navRight = headerNav.getBoundingClientRect().right;
            var children = Array.from(headerNav.children).filter(function(el) {
                return el.offsetWidth > 0;
            });
            var last = children[children.length - 1];
            return last && last.getBoundingClientRect().right > navRight + 1 + overflowBuffer;
        }

        function handleNavOverflow() {
            // On mobile, reset and bail
            if (window.innerWidth < 768) {
                moreItem.style.display = 'none';
                nav.querySelectorAll('.nav-collapsible').forEach(function(el) { el.style.display = ''; });
                return;
            }

            // Reset: show all collapsible items, hide More
            nav.querySelectorAll('.nav-collapsible').forEach(function(el) { el.style.display = ''; });
            moreItem.style.display = 'none';
            while (moreList.firstChild) moreList.removeChild(moreList.firstChild);

            if (!isOverflowing()) return;

            // Show More item first (it takes space)
            moreItem.style.display = '';

            // Collect collapsible items in reverse order (rightmost first)
            var collapsible = Array.from(nav.querySelectorAll('.nav-collapsible')).reverse();

            for (var i = 0; i < collapsible.length; i++) {
                var item = collapsible[i];
                if (!isOverflowing()) break;

                // Hide this item and clone into More
                var link = item.querySelector('a');
                if (link) {
                    var li = document.createElement('li');
                    var a = document.createElement('a');
                    a.className = 'flex items-center gap-2';
                    a.href = link.getAttribute('href');
                    a.textContent = link.textContent.trim();
                    li.appendChild(a);
                    moreList.prepend(li);
                }
                item.style.display = 'none';
            }

            // If nothing in More, hide it
            if (moreList.children.length === 0) {
                moreItem.style.display = 'none';
            }
        }

        var resizeTimer;
        window.addEventListener('resize', function() {
            clearTimeout(resizeTimer);
            resizeTimer = setTimeout(handleNavOverflow, 50);
        });
        // Run after fonts load for accurate measurement
        if (document.fonts && document.fonts.ready) {
            document.fonts.ready.then(handleNavOverflow);
        } else {
            window.addEventListener('load', handleNavOverflow);
        }
        handleNavOverflow();
    })();
</script>
