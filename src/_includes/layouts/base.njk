---
meta:
  language: en-US
  type: page
  site:
    name: FlowFuse
    description: {{ messaging.title }}
    url: https://flowfuse.com
    logo:
      src: https://flowfuse.com/handbook/images/logos/ff-logo--square--dark.png
      width: 396
      height: 215
  author:
    name: FlowFuse
  image:
    src: https://flowfuse.com/handbook/images/logos/ff-logo--square--dark.png
eleventyComputed:
  meta:
    url: "{{ page.url | url | toAbsoluteUrl }}"
    title: "{{ meta.title }}"
    description: "{{ meta.description }}"
    modified: "{{ page.date }}"
    keywords: "{{ meta.keywords }}"
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="/css/style.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Heebo:wght@100..900&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Heebo:wght@100..900&display=swap" rel="stylesheet"></noscript>
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#aa4444">
    <meta name="msapplication-TileColor" content="#00aba9">
    <meta name="theme-color" content="#ffffff">
    
    <!-- Meta Keywords -->
    {% if meta.keywords %}
        <meta name="keywords" content="{{ meta.keywords }}, {{ site.messaging.keywords }}">
    {% elif keywords %}
        <meta name="keywords" content="{{ keywords }}, {{ site.messaging.keywords }}">
    {% elif tags %}
        {% set filtered_tags = tags | reject('equalto', 'posts') | reject('equalto', 'node-red') | list %}
        <meta name="keywords" content="{{ filtered_tags | join(', ') }}, {{ site.messaging.keywords }}">
    {% else %}
        <meta name="keywords" content="{{ site.messaging.keywords }}">
    {% endif %}

    <!-- Browser Title -->
    {% if navTitle %}
    <title>{{ navTitle }} &#x2022; FlowFuse{% if page.url and page.url.match('\/handbook\/.+') %} Handbook{% endif %}{% if page.url and page.url.match('\/docs\/.+') %} Docs{% endif %}</title>
    {% elif meta and meta.title %}
    <title>{{ meta.title }} &#x2022; FlowFuse{% if page.url and page.url.match('\/handbook\/.+') %} Handbook{% endif %}{% if page.url and page.url.match('\/docs\/.+') %} Docs{% endif %}</title>
    {% elif title %}
    <title>{{ title }} &#x2022; FlowFuse{% if page.url and page.url.match('\/handbook\/.+') %} Handbook{% endif %}{% if page.url and page.url.match('\/docs\/.+') %} Docs{% endif %}</title>
    {% else %}
    {% set extractedTitle = content | extractH1Content %}
    {% if extractedTitle and page.url != '/' %}
    <title>{{ extractedTitle }} &#x2022; FlowFuse{% if page.url and page.url.match('\/handbook\/.+') %} Handbook{% endif %}{% if page.url and page.url.match('\/docs\/.+') %} Docs{% endif %}</title>
    {% else %}
    <title>FlowFuse &#x2022; {{ site.messaging.tagLine | replace('<br />', ' ' ) }}</title>
    {% endif %}
    {% endif %}

    <link rel="canonical" href="{{ page.url | toAbsoluteUrl }}">

    <!-- Browser Description -->
    {% if meta and meta.description %}
    <meta name="description" content="{{ meta.description }}">
    {% elif description %}
    <meta name="description" content="{{ description }}">
    {% else %}
    <meta name="description" content="{{ site.messaging.subtitle }}">
    {% endif %}

    {% if skipIndex -%}
    <meta name="robots" content="noindex">
    {%- endif %}

    <!-- Open Graph Title -->
    {% if navTitle %}
    <meta property="og:title" content="{{ navTitle }} &#x2022; FlowFuse{% if page.url and page.url.match('\/handbook\/.+') %} Handbook{% endif %}" />
    {% elif meta and meta.title %}
    <meta property="og:title" content="{{ meta.title }} &#x2022; FlowFuse{% if page.url and page.url.match('\/handbook\/.+') %} Handbook{% endif %}" />
    {% elif title %}
    <meta property="og:title" content="{{ title }} &#x2022; FlowFuse{% if page.url and page.url.match('\/handbook\/.+') %} Handbook{% endif %}" />
    {% else %}
    <meta property="og:title" content="FlowFuse &#x2022; {{ site.messaging.title }}" />
    {% endif %}

    <!-- Open Graph Description -->
    {% if meta and meta.description %}
    <meta property="og:description" content="{{ meta.description }}" />
    {% elif description %}
    <meta property="og:description" content="{{ description }}" />
    {% else %}
    <meta property="og:description" content="{{ site.messaging.subtitle }}" />
    {% endif %}

    <!-- Open Graph URL -->
    <meta property="og:url" content="{{ page.url | toAbsoluteUrl }}" />
    <!-- Open Graph Image -->
    {% if image %}
    <meta property="og:image" content="{{ image | toAbsoluteUrl }}" />
    <meta name="twitter:image" content="{{ image | toAbsoluteUrl }}" />
    {% else %}
    <meta property="og:image" content="{{ 'images/og-social-tile.jpg' | toAbsoluteUrl }}" />
    <meta name="twitter:image" content="{{ 'images/og-social-tile.jpg' | toAbsoluteUrl }}" />
    {% endif %}

    {% if tags and 'posts' in tags %}
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@FlowFuseinc" />
    {% if team[authors|first] and team[authors|first].twitter %}
    <meta name="twitter:creator" content="@{{ team[authors|first].twitter }}" />
    {% else %}
    <meta name="twitter:creator" content="@FlowFuseinc" />
    {% endif %}
    {% else %}
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:description" content="" />
    <meta name="twitter:site" content="@FlowFuseinc" />
    {% endif %}

    {% if nav %}
    <meta property="article:section" content="{{ nav }}" />
    {% endif %}

    {% if type == 'post' %}
    <!-- Article dates -->
    {% if date %}
    <meta property="article:published_time" content="{{ date | dateToRfc3339 }}" />
    {% endif %}
    {% if lastUpdated %}
    <meta property="article:modified_time" content="{{ lastUpdated | dateToRfc3339 }}" />
    {% elif date %}
    <meta property="article:modified_time" content="{{ date | dateToRfc3339 }}" />
    {% endif %}
    {% endif %}

    {% if searchTitle %}
    <meta property="searchable:title" content="{{ searchTitle }}" />
    {% endif %}

    {% set js %}{% include "base.js" %}{% endset %}
    <script>{{ js | jsmin | safe }}</script>
    
    {% include "jsonld.njk" %}

    <script type="module" src="/js/flowrenderer.min.js"></script>

    {%- if not DEV_MODE -%}
    {% include "analytics/head.html" %}
    {%- endif -%}
</head>
<body class="font-sans ff-website leading-normal tracking-normal gradient text-gray-500 min-h-screen flex flex-col">
    <a href="#main-content" class="skip-to-main">Skip to main content</a>
    <!-- Top Utility Bar (announcement + quick links) -->
    {% include "../components/top-utility-bar.njk" %}
    <!-- Navigation Header: direct body child so position:sticky spans the whole page
         (including the footer). When nested in the .base/.w-full wrapper its sticky
         containing block ended at the main content, so the footer scrolled it away. -->
    <header id="ff-header" class="ff-header">
                <nav class="relative w-full flex items-center justify-between xl:grid xl:grid-cols-header mx-auto max-screen-none lg:max-w-screen-xl 2xl:max-w-[1920px]">
                    <a class="ff-logo-link hidden min-[420px]:flex md:hidden lg:flex no-underline hover:no-underline font-bold h-8 w-40 flex-row"  href="/" aria-label="FlowFuse home" style="font-family:'Baloo 2', sans-serif">
                        {% include "components/flowfuse-wordmark.njk" %}
                    </a>
                    <a class="ff-logo-link w-8 h-8 block min-[420px]:hidden md:block lg:hidden shrink-0" href="/" aria-label="FlowFuse home" style="font-family:'Baloo 2', sans-serif">
                        {% include "components/flowfuse-square.svg" %}
                    </a>
                    <div class="flex items-center gap-2 md:hidden relative z-20">
                        <a class="ff-btn ff-btn--primary uppercase text-sm inline-flex whitespace-nowrap" href="/contact-us" onclick="capture('cta-talk-us', {'position': 'header-mobile'})">
                            Contact Us
                        </a>
                        <button id="nav-toggle" class="text-gray-700 flex items-center text-red-hero">
                            <svg class="burger fill-current h-4 w-4" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><title>Menu</title><path d="M0 3h20v2H0V3zm0 6h20v2H0V9zm0 6h20v2H0v-2z"/></svg>
                            <svg class="close fill-current h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                        </button>
                    </div>

                    <!-- Nav -->
                    <ul id="nav-content" class="">
                        {% navoption "Platform", null, 0 %}
                            <ul class="narrow mega md:grid md:grid-flow-col md:grid-rows-[repeat(8,auto)] md:pr-1 md:auto-rows-auto items-center">
                                {% set hl = navHighlights.platform %}{% include "components/nav-highlight.njk" %}
                                {% navoption "Product", null, 1, null, true, "pl-3 title border-l-2 xl:col-start-2 xl:row-start-1" %}{% endnavoption %}
                                <li class="contents">
                                    <ul class="sub-menu grid grid-rows-subgrid row-span-5 ml-7 auto-rows-auto border-l-2 xl:col-start-2 xl:row-start-2">
                                        {% navoption "Features", "/platform/features/", 2, "star" %}{% endnavoption %}
                                        {% navoption "Integrations", "/integrations/", 1, "squares-plus" %}{% endnavoption %}
                                        {% navoption "Blueprint Library", "/blueprints/", 1, "building-library" %}{% endnavoption %}
                                        {% navoption "Security Statement", "/platform/security/", 1, "lock-closed" %}{% endnavoption %}
                                        {% navoption "Pricing", "/pricing/", 1, "dollar" %}{% endnavoption %}
                                    </ul>
                                </li>
                                {% navoption "Components", null, 1, null, true, "pl-3 title border-l-2 md:col-start-2 md:row-start-1 xl:col-start-3" %}{% endnavoption %}
                                <li class="contents">
                                    <ul class="sub-menu grid grid-rows-subgrid row-span-4 ml-7 auto-rows-auto border-l-2 md:col-start-2 md:row-start-2 xl:col-start-3">
                                        {% navoption "FlowFuse Dashboard", "/platform/dashboard/", 2, "dashboard" %}{% endnavoption %}
                                        {% navoption "Device Agent", "/platform/device-agent/", 2, "device-agent" %}{% endnavoption %}
                                        {% navoption "Node-RED", "/node-red/", 2, "code-bracket" %}{% endnavoption %}
                                        {% navoption "FlowFuse Expert", "/docs/user/expert/", 1, "sparkles" %}{% endnavoption %}
                                    </ul>
                                </li>
                                {% navoption "Capabilities", null, 1, null, true, "pl-3 title border-l-2 md:col-start-3 md:row-start-1 xl:col-start-4" %}{% endnavoption %}
                                <li class="contents">
                                    <ul class="sub-menu grid grid-rows-subgrid row-span-[7] ml-7 auto-rows-auto border-l-2 md:col-start-3 md:row-start-2 xl:col-start-4">
                                        {% navoption "Industrial AI", "/ai/", 1, "sparkles" %}{% endnavoption %}
                                        {% navoption "IT/OT middleware", "/use-cases/it-ot-middleware/", 1, "cog" %}{% endnavoption %}
                                        {% navoption "Unified Namespace", "/use-cases/uns/", 1, "uns" %}{% endnavoption %}
                                        {% navoption "MES", "/use-cases/mes/", 1, "chart" %}{% endnavoption %}
                                        {% navoption "SCADA", "/use-cases/scada/", 1, "screen" %}{% endnavoption %}
                                        {% navoption "Edge Connectivity", "/use-cases/edge-connectivity/", 1, "chip" %}{% endnavoption %}
                                        {% navoption "Data Integration", "/use-cases/data-integration/", 1, "arrows-right-left" %}{% endnavoption %}
                                    </ul>
                                </li>
                            </ul>
                        {% endnavoption %}
                        {% navoption "Solutions", null, 0 %}
                        <ul class="narrow mega md:grid md:grid-flow-col md:grid-rows-[repeat(12,auto)] md:pr-1 md:auto-rows-auto items-center">
                            {% set hl = navHighlights.solutions %}{% include "components/nav-highlight.njk" %}
                            {% navoption "By Use Case", null, 1, null, true, "pl-3 title border-l-2 xl:col-start-2 xl:row-start-1" %}{% endnavoption %}
                            <li class="contents">
                                <ul class="sub-menu grid grid-rows-subgrid row-span-[11] ml-7 auto-rows-auto border-l-2 xl:col-start-2 xl:row-start-2">
                                    {% navoption "Production Monitoring", "/use-cases/production-monitoring/", 1, "pulse" %}{% endnavoption %}
                                    {% navoption "Operational Data Pipelines", "/use-cases/operational-data-pipelines/", 1, "arrows-right-left" %}{% endnavoption %}
                                    {% navoption "Equipment Monitoring", "/use-cases/equipment-monitoring/", 1, "bell-alert" %}{% endnavoption %}
                                    {% navoption "Quality Validation", "/use-cases/quality-validation/", 1, "check-circle" %}{% endnavoption %}
                                    {% navoption "Track & Trace", "/use-cases/track-and-trace/", 1, "queue-list" %}{% endnavoption %}
                                    {% navoption "System Diagnostics", "/use-cases/system-diagnostics/", 1, "eye" %}{% endnavoption %}
                                    {% navoption "Shop Floor Communication", "/use-cases/shop-floor-communication/", 1, "chat" %}{% endnavoption %}
                                    {% navoption "Workforce Assignment", "/use-cases/workforce-assignment/", 1, "users" %}{% endnavoption %}
                                    {% navoption "Continuous Improvement", "/use-cases/continuous-improvement/", 1, "arrow-path" %}{% endnavoption %}
                                    {% navoption "Governed AI & Agent Access", "/use-cases/governed-ai-access/", 1, "sparkles" %}{% endnavoption %}
                                    {% navoption "See all use cases", "/use-cases/", 1, "arrow-right" %}{% endnavoption %}
                                </ul>
                            </li>
                            {% navoption "By Industry", null, 1, null, true, "pl-3 title border-l-2 md:col-start-2 md:row-start-1 xl:col-start-3" %}{% endnavoption %}
                            <li class="contents">
                                <ul class="sub-menu grid grid-rows-subgrid row-span-[9] ml-7 auto-rows-auto border-l-2 md:col-start-2 md:row-start-2 xl:col-start-3">
                                    {% navoption "Automotive", "/industries/automotive/", 1, "car" %}{% endnavoption %}
                                    {% navoption "Food & Beverage", "/industries/food-beverage/", 1, "snowflake" %}{% endnavoption %}
                                    {% navoption "Life Sciences", "/industries/life-sciences/", 1, "shield-check" %}{% endnavoption %}
                                    {% navoption "Electronics & Appliances", "/industries/electronics-appliances/", 1, "power" %}{% endnavoption %}
                                    {% navoption "Renewables", "/industries/renewables/", 1, "wind-turbine" %}{% endnavoption %}
                                    {% navoption "Semiconductors", "/industries/semiconductors/", 1, "chip" %}{% endnavoption %}
                                    {% navoption "Aerospace Components", "/industries/aerospace-components/", 1, "cog-6-tooth" %}{% endnavoption %}
                                    {% navoption "Aviation Aerospace", "/industries/aviation-aerospace/", 1, "airplane" %}{% endnavoption %}
                                    {% navoption "See all industries", "/industries/", 1, "arrow-right" %}{% endnavoption %}
                                </ul>
                            </li>
                            {% navoption "By Outcome", null, 1, null, true, "pl-3 title border-l-2 md:col-start-3 md:row-start-1 xl:col-start-4" %}{% endnavoption %}
                            <li class="contents">
                                <ul class="sub-menu grid grid-rows-subgrid row-span-6 ml-7 auto-rows-auto border-l-2 md:col-start-3 md:row-start-2 xl:col-start-4">
                                    {% navoption "Production Performance", "/outcomes/production-performance/", 1, "arrow-trending-up" %}{% endnavoption %}
                                    {% navoption "Quality & Compliance", "/outcomes/quality-compliance/", 1, "shield-check" %}{% endnavoption %}
                                    {% navoption "Labor & Operational Efficiency", "/outcomes/labor-operational-efficiency/", 1, "users" %}{% endnavoption %}
                                    {% navoption "Asset Reliability", "/outcomes/asset-reliability/", 1, "wrench-screwdriver" %}{% endnavoption %}
                                    {% navoption "AI Readiness & Data Foundation", "/outcomes/ai-readiness-data-foundation/", 1, "sparkles" %}{% endnavoption %}
                                    {% navoption "See all outcomes", "/outcomes/", 1, "arrow-right" %}{% endnavoption %}
                                </ul>
                            </li>
                        </ul>
                        {% endnavoption %}
                        {% navoption "Resources", null, 0 %}
                            <ul class="narrow mega md:grid md:grid-flow-col md:grid-rows-[repeat(5,auto)] md:pr-1 md:auto-rows-auto items-center">
                                {% set latestPost = collections.posts | reverse | first %}{% set hl = { title: latestPost.data.title, link: latestPost.url } %}{% include "components/nav-highlight.njk" %}
                                {% navoption "Learn", null, 1, null, true, "pl-3 title border-l-2 xl:col-start-2 xl:row-start-1" %}{% endnavoption %}
                                <li class="contents">
                                    <ul class="sub-menu grid grid-rows-subgrid row-span-4 ml-7 auto-rows-auto border-l-2 xl:col-start-2 xl:row-start-2">
                                        {% navoption "Blog", "/blog/", 1, "newspaper" %}{% endnavoption %}
                                        {% navoption "Webinars", "/webinars/", 1, "screen" %}{% endnavoption %}
                                        {% navoption "Publications", "/resources/publications/", 1, "book-open" %}{% endnavoption %}
                                        {% navoption "Node-RED Academy", "https://node-red-academy.learnworlds.com/", 1, "academic-cap" %}{% endnavoption %}
                                    </ul>
                                </li>
                                {% navoption "Reference", null, 1, null, true, "pl-3 title border-l-2 md:col-start-2 md:row-start-1 xl:col-start-3" %}{% endnavoption %}
                                <li class="contents">
                                    <ul class="sub-menu grid grid-rows-subgrid row-span-4 ml-7 auto-rows-auto border-l-2 md:col-start-2 md:row-start-2 xl:col-start-3">
                                        {% navoption "Docs", "/docs/", 1, "document-text" %}{% endnavoption %}
                                        {% navoption "Changelog", "/changelog/", 1, "rocket-launch" %}{% endnavoption %}
                                        {% navoption "Github", "https://github.com/FlowFuse/flowfuse", 1, "github", true %}{% endnavoption %}
                                        {% navoption "Support forums", "https://discourse.nodered.org/c/vendors/flowfuse/24/", 1, "chat-bubble-left-right-sm" %}{% endnavoption %}
                                    </ul>
                                </li>
                                {% navoption "Customers", null, 1, null, true, "pl-3 title border-l-2 md:col-start-3 md:row-start-1 xl:col-start-4" %}{% endnavoption %}
                                <li class="contents">
                                    <ul class="sub-menu grid grid-rows-subgrid row-span-2 ml-7 auto-rows-auto border-l-2 md:col-start-3 md:row-start-2 xl:col-start-4">
                                        {% navoption "Customer Stories", "/customer-stories/", 1, "presentation" %}{% endnavoption %}
                                        {% navoption "Educational License", "/education/", 1, "certificate" %}{% endnavoption %}
                                    </ul>
                                </li>
                            </ul>
                        {% endnavoption %}
                        {% navoption "Company", null, 0 %}
                            <ul class="narrow mega md:grid md:grid-flow-col md:grid-rows-[repeat(5,auto)] md:pr-1 md:auto-rows-auto items-center">
                                {% set hl = navHighlights.company %}{% include "components/nav-highlight.njk" %}
                                {% navoption "Company", null, 1, null, true, "pl-3 title border-l-2 xl:col-start-2 xl:row-start-1" %}{% endnavoption %}
                                <li class="contents">
                                    <ul class="sub-menu grid grid-rows-subgrid row-span-4 ml-7 auto-rows-auto border-l-2 xl:col-start-2 xl:row-start-2">
                                        {% navoption "Why FlowFuse", "/platform/why-flowfuse/", 1, "flowfuse" %}{% endnavoption %}
                                        {% navoption "About us", "/about/", 1, "building-office-2" %}{% endnavoption %}
                                        {% navoption "Jobs", site.jobBoard, 1, "case" %}{% endnavoption %}
                                        {% navoption "Handbook", "/handbook/", 1, "book-open" %}{% endnavoption %}
                                    </ul>
                                </li>
                                {% navoption "Partners & Services", null, 1, null, true, "pl-3 title border-l-2 md:col-start-2 md:row-start-1 xl:col-start-3" %}{% endnavoption %}
                                <li class="contents">
                                    <ul class="sub-menu grid grid-rows-subgrid row-span-2 ml-7 auto-rows-auto border-l-2 md:col-start-2 md:row-start-2 xl:col-start-3">
                                        {% navoption "Partnerships", "/partners/", 1, "user-group" %}{% endnavoption %}
                                        {% navoption "Professional Services", "/professional-services/", 1, "wrench-screwdriver" %}{% endnavoption %}
                                    </ul>
                                </li>
                                {% navoption "Support", null, 1, null, true, "pl-3 title border-l-2 md:col-start-3 md:row-start-1 xl:col-start-4" %}{% endnavoption %}
                                <li class="contents">
                                    <ul class="sub-menu grid grid-rows-subgrid row-span-3 ml-7 auto-rows-auto border-l-2 md:col-start-3 md:row-start-2 xl:col-start-4">
                                        {% navoption "Service Status", "https://status.flowfuse.com/", 1, "check-badge", true %}{% endnavoption %}
                                        {% navoption "Request Support", "/support/", 1, "lifebuoy" %}{% endnavoption %}
                                        {% navoption "Contact Us", "/contact-us/", 1, "mail" %}{% endnavoption %}
                                    </ul>
                                </li>
                            </ul>
                        {% endnavoption %}
                        {% navoption "Industrial AI", "/ai/", 0, false, false, "nav-collapsible" %}{% endnavoption %}
                        <!-- More dropdown for overflow items -->
                        <li id="nav-more" class="ff-nav-dropdown relative hover:cursor-pointer" style="display:none">
                            <span class="flex items-center gap-1">More<span class="ff-nav-chevron">{% include "components/icons/chevron-down.svg" %}</span></span>
                            <ul id="nav-more-list" class="align-left"></ul>
                        </li>
                    </ul>
                    <!-- CTAs -->
                    <ul class="cta hidden md:flex flex-row items-center justify-end font-medium text no-underline z-10 bg-transparent w-auto">
			            <li class="hidden md:flex"><a class="ff-nav-freetrial" href="{% include "sign-up-url.njk" %}" onclick="capture('cta-join', {'position': 'header'})"><span class="ff-nav-label">Free Trial</span></a></li>
                        <li class="flex">
                            <a class="ml-2 ff-btn ff-btn--primary uppercase text-sm inline-flex whitespace-nowrap" href="/contact-us" onclick="capture('cta-talk-us', {'position': 'header'})">
                                Contact Us
                            </a>
                        </li>
                    </ul>
                </nav>
                <!-- Mobile CTAs -->
                <div id="mobile-ctas" class="hidden fixed bottom-0 z-20">
                    <div class="grid grid-cols-2 gap-2">
                        <a href="{{ site.appURL }}" class="ff-btn ff-btn--primary-outlined">Sign In</a>
                        <a href="{% include "sign-up-url.njk" %}" onclick="capture('cta-join', {'position': 'header'})" class="ff-btn ff-btn--primary-outlined">Free Trial</a>
                    </div>
                    <a class="ff-btn ff-btn--primary" href="/contact-us" onclick="capture('cta-talk-to-sales', {'position': 'header'})">Contact Us</a>
                </div>
            </header>
    <!-- Main Content: wrapped in the flex-grow base so the column layout still
         pushes the footer to the bottom on short pages -->
    <div class="flex-grow base">
        <div class="w-full">
            <!-- Main Content -->
            <main id="main-content" class="flex flex-col mx-auto items-center justify-center gradient-bg">
                {{ content | safe }}
            </main>
        </div>
    </div>
    <!-- Hannover Messe 2026 Promo Banner -->
    {% include "components/hm-promo-banner.njk" %}
    <!-- Footer -->
    <footer class="ff-footer bg-gray-100 w-full border-t border-white">
        <div class="pt-20 pb-12 px-6 max-w-screen-xl mx-auto">
            <!-- Sections synced with the top nav: Platform / Solutions / Resources / Company -->
