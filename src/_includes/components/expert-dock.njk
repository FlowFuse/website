{# ============================================================
   EXPERT DOCK - sticky bar pinned to the viewport bottom on
   use-case pages. Collapsed by default; the button opens the
   existing FlowFuse Expert chat modal (ai-expert-modal.njk binds
   #tell-me-how-btn in ai-expert-modal.js, textarea optional).
   ============================================================ #}
<div id="expert-dock" class="fixed bottom-0 inset-x-0 z-40 px-4 pb-3 pointer-events-none">
    <div class="max-w-screen-md mx-auto pointer-events-auto">
        <div class="flex items-center justify-between gap-4 rounded-xl border border-indigo-200 bg-white/95 backdrop-blur shadow-lg px-5 py-3">
            <div class="flex items-center gap-3 min-w-0">
                <span class="w-6 h-6 text-indigo-600 flex-shrink-0">{% include "components/icons/sparkles.svg" %}</span>
                <p class="m-0 text-sm text-gray-700 truncate">Ask the FlowFuse Expert how this use case would work on your operations.</p>
            </div>
            <button id="tell-me-how-btn" class="ff-btn ff-btn--highlight uppercase whitespace-nowrap flex-shrink-0 px-4 py-2 text-sm" onclick="if(typeof capture === 'function') capture('cta-expert-dock', {'position': 'dock', 'usecase': '{{ page.fileSlug }}'})">
                Ask the Expert
            </button>
        </div>
    </div>
</div>
{% include "components/ai-expert-modal.njk" %}
