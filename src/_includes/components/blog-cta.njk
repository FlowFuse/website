<div class="ff-blue-card flex flex-col sm:flex-row gap-6 not-prose">
    <div class="flex flex-col gap-4 sm:w-2/5">
        <h3 class="text-2xl text-gray-900 leading-tight">{{ ctaTitle }}</h3>
        <a href="{{ ctaUrl }}"
           onclick='capture("cta-{{ ctaButtonText | downcase | replace: " ", "-" }}", {"reference": "Blog: {{ title }}"})'
           class="ff-btn ff-btn--highlight uppercase self-start">
            {{ ctaButtonText }}
        </a>
    </div>
    <div class="sm:w-3/5 text-gray-600 text-base leading-relaxed">
        {{ ctaMessage }}
    </div>
</div>
