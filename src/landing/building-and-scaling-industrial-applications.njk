                        <li class="flex items-start gap-3">
                            <div class="w-8 h-8 min-w-[2rem] rounded-full bg-gray-100 flex items-center flex-shrink-0">
                                <div class="w-5 h-5 text-gray-400">{% include item.icon %}</div>
                            </div>
                            <span class="text-base leading-snug pt-1">{{ item.text | safe }}</span>
                        </li>
                        {% endfor %}
                    </ul>
                </div>

                <!-- FlowFuse card -->
                <div class="md:w-1/2 bg-white rounded-xl shadow-lg border border-red-400 overflow-hidden">
                    <div class="bg-red-50 px-8 min-h-[6rem] flex items-center justify-center border-b border-red-200">
                        <h2 class="text-center text-red-500 font-medium text-2xl m-0">
