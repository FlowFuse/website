                            <div class="w-5 h-5 text-indigo-600">{% include "components/icons/document-text.svg" %}</div>
                        </div>
                        <h3 class="font-medium text-xl m-0 text-gray-900">Download the brief</h3>
                    </div>
                    {% include hubspot.script %}
                </div>

            </div>
        </div>
