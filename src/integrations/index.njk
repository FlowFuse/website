---
layout: layouts/base.njk
sitemapPriority: 0.9
hideTitle: true
title: Integrations
description: Enterprise-grade certified integrations and 5,000+ community nodes for Node-RED.
meta:
    title: "Certified Integrations for Node-RED | FlowFuse"
    description: "Enterprise-grade certified integrations and 5,000+ community nodes for Node-RED. Commercially supported with guaranteed SLAs."
    keywords: "Node-RED integrations, certified nodes, OPC-UA, MQTT, Modbus, industrial automation, FlowFuse"
---

{# --- Hero Section --- #}
<div class="w-full" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);">
    <div class="px-6 py-16 container mx-auto md:max-w-screen-lg text-center">
        <p class="text-green-400 font-semibold uppercase tracking-widest text-sm mb-3">Enterprise-Grade Connectivity</p>
        <h1 class="text-white font-bold text-3xl md:text-4xl mt-0 mb-4">Certified Integrations for Node-RED</h1>
        <p class="text-gray-300 max-w-2xl mx-auto mb-10 text-lg">
            Commercially supported, rigorously tested connectors with guaranteed SLAs.
            Built for production environments that demand reliability.
        </p>
        <div class="flex gap-8 sm:gap-12 justify-center flex-wrap">
            <div class="text-center">
                <div class="text-3xl font-bold text-green-400">{{ certifiedIntegrations.integrations | length }}+</div>
                <div class="text-xs text-gray-400 mt-1">Certified Integrations</div>
            </div>
            <div class="text-center">
                <div class="text-3xl font-bold text-green-400">99.9%</div>
                <div class="text-xs text-gray-400 mt-1">Uptime SLA</div>
            </div>
            <div class="text-center">
                <div class="text-3xl font-bold text-green-400">24h</div>
                <div class="text-xs text-gray-400 mt-1">Support Response</div>
            </div>
            <div class="text-center">
                <div class="text-3xl font-bold text-green-400">5,000+</div>
                <div class="text-xs text-gray-400 mt-1">Community Nodes</div>
            </div>
        </div>
    </div>
</div>

{# --- Category Filter Bar --- #}
<div class="w-full border-b border-gray-200 bg-gray-50 sticky top-0 z-10">
    <div class="px-6 py-3 container mx-auto md:max-w-screen-lg">
        <div class="flex items-center gap-3 flex-wrap" id="filter-pills">
            <button class="bg-gray-900 text-white border border-gray-900 px-4 py-1.5 rounded-full text-sm cursor-pointer transition-all" data-category="all" onclick="filterIntegrations('all', this)">All</button>
            {% for cat in certifiedIntegrations.categories %}
            <button class="bg-white border border-gray-200 px-4 py-1.5 rounded-full text-sm text-gray-600 cursor-pointer transition-all hover:border-gray-400" data-category="{{ cat.slug }}" onclick="filterIntegrations('{{ cat.slug }}', this)">{{ cat.name }}</button>
            {% endfor %}
        </div>
    </div>
</div>

{# --- Certified Integrations Grid --- #}
<div class="w-full px-6 py-12">
    <div class="container mx-auto md:max-w-screen-lg">
        <div class="flex items-center gap-3 mb-6">
            <span class="bg-green-100 text-green-800 text-xs font-bold px-3 py-1 rounded uppercase tracking-wide">Certified</span>
            <span class="text-lg font-bold">Enterprise Integrations</span>
        </div>
        <div id="certified-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {% for integration in certifiedIntegrations.integrations %}
            <a href="/integrations/{{ integration.slug }}/"
               class="certified-integration-card group block border-2 border-green-100 rounded-xl p-6 bg-white hover:border-green-300 hover:shadow-lg transition-all hover:no-underline"
               data-category="{{ integration.category }}">
                <div class="flex justify-between items-start mb-3">
                    <div class="w-12 h-12 bg-green-50 rounded-lg flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-green-600">
                            <path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0 1 12 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 0 1 3.498 1.307 4.491 4.491 0 0 1 1.307 3.497A4.49 4.49 0 0 1 21.75 12a4.49 4.49 0 0 1-1.549 3.397 4.491 4.491 0 0 1-1.307 3.497 4.491 4.491 0 0 1-3.497 1.307A4.49 4.49 0 0 1 12 21.75a4.49 4.49 0 0 1-3.397-1.549 4.49 4.49 0 0 1-3.498-1.306 4.491 4.491 0 0 1-1.307-3.498A4.49 4.49 0 0 1 2.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 0 1 1.307-3.497 4.49 4.49 0 0 1 3.497-1.307Zm7.007 6.387a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" />
                        </svg>
                    </div>
                    <span class="bg-green-700 text-white text-[10px] font-bold px-2 py-0.5 rounded uppercase">Certified</span>
                </div>
                <h3 class="text-lg font-bold mt-0 mb-1 group-hover:text-indigo-600 transition-colors">{{ integration.name }}</h3>
                <p class="text-sm text-gray-600 mb-3" style="-webkit-line-clamp: 2; display: -webkit-box; -webkit-box-orient: vertical; overflow: hidden;">{{ integration.description }}</p>
                <div class="flex flex-wrap gap-2 mb-3">
                    {% for cat in certifiedIntegrations.categories %}
                        {% if cat.slug == integration.category %}
                        <span class="bg-gray-100 text-gray-600 text-[10px] px-2 py-0.5 rounded">{{ cat.name }}</span>
                        {% endif %}
                    {% endfor %}
                    {% if integration.certifiedNodes.length > 0 %}
                    <span class="bg-gray-100 text-gray-600 text-[10px] px-2 py-0.5 rounded">{{ integration.certifiedNodes.length }} node{{ "s" if integration.certifiedNodes.length > 1 }}</span>
                    {% endif %}
                </div>
                <div class="flex items-center gap-3 text-[11px] text-gray-400">
                    <span class="flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5 text-green-500">
                            <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                        </svg>
                        SLA Backed
                    </span>
                    <span class="flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5 text-green-500">
                            <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                        </svg>
                        Commercial Support
                    </span>
                </div>
            </a>
            {% endfor %}
        </div>
    </div>
</div>

{# --- Divider --- #}
<div class="w-full px-6">
    <div class="container mx-auto md:max-w-screen-lg border-t border-gray-200"></div>
</div>

{# --- Community Nodes Section --- #}
<div class="w-full px-6 py-12">
    <div class="container mx-auto md:max-w-screen-lg">
        <div class="flex items-center gap-3 mb-2">
            <span class="bg-gray-100 text-gray-600 text-xs font-bold px-3 py-1 rounded uppercase tracking-wide">Community</span>
            <span class="text-lg font-bold">Node-RED Ecosystem</span>
        </div>
        <p class="text-gray-500 text-sm mb-6">5,000+ nodes from the open-source Node-RED community, sorted by popularity.</p>

        <input id="search-catalogue" class="w-full max-w-md border border-gray-300 rounded-lg px-4 py-2 text-sm mb-6 focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-300"
               type="text" placeholder="Search community nodes..." onkeyup="filterCatalogue()" onchange="filterCatalogue()"/>

        <ul id="community-tiles-placeholder" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
            <li class="border border-gray-200 rounded-lg p-4 bg-gray-50 animate-pulse h-28"></li>
            <li class="border border-gray-200 rounded-lg p-4 bg-gray-50 animate-pulse h-28"></li>
            <li class="border border-gray-200 rounded-lg p-4 bg-gray-50 animate-pulse h-28"></li>
            <li class="border border-gray-200 rounded-lg p-4 bg-gray-50 animate-pulse h-28"></li>
        </ul>
        <ul id="community-tiles" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3"></ul>

        <nav id="catalog-pagination" style="display: none;" aria-labelledby="pagination" class="pagination mt-6">
            <ol class="flex flex-row w-full justify-between text-gray-600 text-sm">
                <li id="pagination-previous" class="cursor-pointer hover:text-indigo-600" onclick="changePage(-1)">&larr; Previous</li>
                <li><span id="pagination-current">1</span> of <span id="pagination-max">1</span></li>
                <li id="pagination-next" class="cursor-pointer hover:text-indigo-600" onclick="changePage(1)">Next &rarr;</li>
            </ol>
        </nav>
    </div>
</div>

{# --- Bottom CTA --- #}
<div class="w-full bg-gray-50 py-12 px-6 border-t border-gray-200">
    <div class="container mx-auto md:max-w-screen-lg text-center">
        <h2 class="text-2xl font-bold mb-3">Need a custom integration?</h2>
        <p class="text-gray-600 mb-6 max-w-lg mx-auto">Our engineering team can certify and support additional Node-RED nodes for your environment.</p>
        <div class="flex gap-3 justify-center flex-wrap">
            <a class="ff-btn ff-btn--primary min-h-[40px]" href="/contact-us/"
               onclick="capture('cta-contact-us', {'position': 'secondary'}, {'page': 'integrations-catalog'})">CONTACT SALES</a>
            <a class="ff-btn ff-btn--primary-outlined min-h-[40px]" href="{% include 'sign-up-url.njk' %}"
               onclick="capture('cta-get-started', {'position': 'secondary'}, {'page': 'integrations-catalog'})">START FREE TRIAL</a>
        </div>
    </div>
</div>

<script>
    /* Category filter for certified integrations */
    function filterIntegrations(category, btn) {
        var pills = document.getElementById('filter-pills').children;
        for (var i = 0; i < pills.length; i++) {
            pills[i].className = 'bg-white border border-gray-200 px-4 py-1.5 rounded-full text-sm text-gray-600 cursor-pointer transition-all hover:border-gray-400';
        }
        btn.className = 'bg-gray-900 text-white border border-gray-900 px-4 py-1.5 rounded-full text-sm cursor-pointer transition-all';

        var cards = document.querySelectorAll('.certified-integration-card');
        for (var j = 0; j < cards.length; j++) {
            if (category === 'all' || cards[j].getAttribute('data-category') === category) {
                cards[j].style.display = '';
            } else {
                cards[j].style.display = 'none';
            }
        }
    }

    /* Community nodes - client-side catalog */
    var communityPagination = { perPage: 24, currentPage: 0, maxPage: 0 };
    var catalogue = [];

    /* Set of certified node IDs to exclude from community section */
    var certifiedIds = {};
    {%- for integration in certifiedIntegrations.integrations -%}
        {%- for nodeId in integration.certifiedNodes -%}
    certifiedIds["{{ nodeId }}"] = true;
        {%- endfor -%}
    {%- endfor -%}

    function loadCatalogue() {
        fetch('https://ff-integrations.flowfuse.cloud/api/nodes')
            .then(function(response) { return response.json(); })
            .then(function(data) {
                var placeholder = document.getElementById('community-tiles-placeholder');
                if (placeholder) placeholder.style.display = 'none';
                document.getElementById('catalog-pagination').style.display = '';

                catalogue = data.catalogue.filter(function(node) {
                    return !certifiedIds[node._id] && !node.ffCertified;
                });
                communityPagination.maxPage = Math.ceil(catalogue.length / communityPagination.perPage);
                filterCatalogue();
            })
            .catch(function(err) {
                console.error('Failed to load community nodes:', err);
            });
    }
    loadCatalogue();

    function truncateText(str, words) {
        if (!str) return '';
        var parts = str.split(' ');
        if (parts.length <= words) return str;
        return parts.slice(0, words).join(' ') + '...';
    }

    function filterCatalogue() {
        var search = document.getElementById('search-catalogue').value.toLowerCase();
        var filtered = catalogue
            .filter(function(node) {
                return node._id.toLowerCase().indexOf(search) !== -1 ||
                       (node.description || '').toLowerCase().indexOf(search) !== -1;
            })
            .sort(function(a, b) {
                return (b.downloads ? b.downloads.week : 0) - (a.downloads ? a.downloads.week : 0);
            });

        communityPagination.maxPage = Math.ceil(filtered.length / communityPagination.perPage) || 1;
        if (communityPagination.currentPage >= communityPagination.maxPage) {
            communityPagination.currentPage = communityPagination.maxPage - 1;
        }

        document.getElementById('pagination-current').textContent = communityPagination.currentPage + 1;
        document.getElementById('pagination-max').textContent = communityPagination.maxPage;
        document.getElementById('pagination-previous').style.visibility = communityPagination.currentPage === 0 ? 'hidden' : '';
        document.getElementById('pagination-next').style.visibility = communityPagination.currentPage + 1 >= communityPagination.maxPage ? 'hidden' : '';

        var tiles = document.getElementById('community-tiles');
        tiles.textContent = '';
        var start = communityPagination.currentPage * communityPagination.perPage;
        var page = filtered.slice(start, start + communityPagination.perPage);

        page.forEach(function(node) {
            var li = document.createElement('li');
            li.className = 'border border-gray-200 rounded-lg p-4 bg-white hover:border-gray-400 hover:shadow-sm transition-all';

            var a = document.createElement('a');
            a.href = 'https://flows.nodered.org/node/' + node._id;
            a.target = '_blank';
            a.rel = 'noopener noreferrer';
            a.className = 'block hover:no-underline';

            var nameDiv = document.createElement('div');
            nameDiv.className = 'font-semibold text-sm text-gray-800 truncate';
            nameDiv.textContent = node._id;

            var descP = document.createElement('p');
            descP.className = 'text-xs text-gray-500 mt-1 mb-2';
            descP.style.cssText = '-webkit-line-clamp: 2; display: -webkit-box; -webkit-box-orient: vertical; overflow: hidden;';
            descP.textContent = node.description || '';

            var dlDiv = document.createElement('div');
            dlDiv.className = 'text-[10px] text-gray-400';
            dlDiv.textContent = (node.downloads ? node.downloads.week : 0).toLocaleString() + ' weekly downloads';

            a.appendChild(nameDiv);
            a.appendChild(descP);
            a.appendChild(dlDiv);
            li.appendChild(a);
            tiles.appendChild(li);
        });
    }

    function changePage(diff) {
        var next = communityPagination.currentPage + diff;
        if (next < 0 || next >= communityPagination.maxPage) return;
        communityPagination.currentPage = next;
        filterCatalogue();
        document.getElementById('community-tiles').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
</script>
